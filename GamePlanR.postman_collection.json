        {
          "name": "Available Slots",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var d = pm.response.json();",
                  "if (Array.isArray(d) && d.length > 0) pm.collectionVariables.set('timeslot_id', d[0].id);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/venues/{{venue_id}}/available-slots/?date=2026-05-28",
              "host": ["{{base_url}}"],
              "path": ["venues", "{{venue_id}}", "available-slots", ""],
              "query": [{ "key": "date", "value": "2026-05-28" }]
            }
          }
        }
      ]
    },
