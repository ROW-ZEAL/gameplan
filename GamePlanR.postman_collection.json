{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-gameplanr001",
    "name": "GamePlanR API",
    "description": "Sports venue booking platform.\n\nFlow:\n1. Register or Login → access_token and refresh_token are auto-saved\n2. All protected endpoints use Bearer {{access_token}} from collection auth\n3. After 60 min, call Refresh Token to rotate tokens\n4. Set venue_id and timeslot_id manually from List Venues / Available Slots responses",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "base_url",             "value": "http://127.0.0.1:8000/api", "type": "string" },
    { "key": "access_token",         "value": "", "type": "string" },
    { "key": "refresh_token",        "value": "", "type": "string" },
    { "key": "venue_id",             "value": "", "type": "string" },
    { "key": "timeslot_id",          "value": "", "type": "string" },
    { "key": "sport_category_id",    "value": "", "type": "string" },
    { "key": "booking_id",           "value": "", "type": "string" },
    { "key": "payment_id",           "value": "", "type": "string" },
    { "key": "opponent_request_id",  "value": "", "type": "string" },
    { "key": "notification_id",      "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var d = pm.response.json();",
                  "if (d.access)  pm.collectionVariables.set('access_token',  d.access);",
                  "if (d.refresh) pm.collectionVariables.set('refresh_token', d.refresh);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"full_name\": \"Test User\",\n  \"phone_number\": \"+9771234567890\",\n  \"password\": \"TestPass123!\",\n  \"password2\": \"TestPass123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/register/",
              "host": ["{{base_url}}"],
              "path": ["auth", "register", ""]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var d = pm.response.json();",
                  "if (d.access)  pm.collectionVariables.set('access_token',  d.access);",
                  "if (d.refresh) pm.collectionVariables.set('refresh_token', d.refresh);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"TestPass123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["auth", "login", ""]
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var d = pm.response.json();",
                  "if (d.access)  pm.collectionVariables.set('access_token',  d.access);",
                  "if (d.refresh) pm.collectionVariables.set('refresh_token', d.refresh);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh/",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh", ""]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/logout/",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout", ""]
            }
          }
        },
        {
          "name": "My Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/me/",
              "host": ["{{base_url}}"],
              "path": ["auth", "me", ""]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Updated Name\",\n  \"phone_number\": \"+9779876543210\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/me/",
              "host": ["{{base_url}}"],
              "path": ["auth", "me", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Sport Categories",
      "item": [
