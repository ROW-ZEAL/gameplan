          "name": "List Sport Categories",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var d = pm.response.json();",
                  "if (d.length > 0) pm.collectionVariables.set('sport_category_id', d[0].id);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/sport-categories/",
              "host": ["{{base_url}}"],
              "path": ["sport-categories", ""]
            }
          }
        }
      ]
    },
    {
